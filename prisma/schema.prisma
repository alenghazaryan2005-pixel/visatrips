generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  // Legacy (kept for in-place migration; data will be migrated to new values)
  PENDING
  UNDER_REVIEW
  APPROVED
  // Active statuses
  UNFINISHED          // Customer paid, hasn't completed the finish page yet
  PROCESSING          // Customer finished application, we need to review
  SUBMITTED           // We submitted to gov site, got Application ID
  COMPLETED           // Visa delivered, or abandoned after 3 reminders
  NEEDS_CORRECTION    // Waiting on customer to fix flagged fields
  ON_HOLD             // Paused manually by admin
  REJECTED            // Visa rejected by gov
  REFUNDED            // Order refunded
}

model Order {
  id           String      @id @default(cuid())
  orderNumber  Int         @default(autoincrement())
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  destination  String
  visaType     String
  totalUSD     Float
  status       OrderStatus @default(UNFINISHED)
  notes        String?
  travelers    String
  billingEmail String
  cardLast4       String?
  processingSpeed String   @default("standard")
  lastEditedBy    String?
  applicationId   String?
  evisaUrl         String?
  flaggedFields    String?  // JSON array of field names
  specialistNotes  String?  // Customer-visible correction notes
  botFlags         String?  // JSON array of bot processing issues that need manual attention
  refundAmount     Float?
  refundReason    String?
  refundedAt      DateTime?
  // Reminders for UNFINISHED orders
  reminderCount    Int      @default(0)
  lastReminderAt   DateTime?
  completedAt      DateTime?
  submittedAt      DateTime?
  // Track which emails have been sent (JSON: { "confirmation": "2026-04-18T...", "correction": "...", ... })
  emailHistory     String?   @db.Text

  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

model AbandonedApplication {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  destination String?
  visaType    String?
  email       String?
  travelers   String?  // JSON string of partial traveler data
  passportData String? // JSON string of partial passport data
  lastStep    String   @default("step1") // step1, step2, step2b, step3
  ipAddress   String?
  userAgent   String?

  @@index([createdAt])
  @@index([email])
  @@map("abandoned_applications")
}

model CrmCustomer {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  phone     String?
  tags      String?  // comma-separated tags
  notes     String?  // internal CRM notes
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  activities CrmActivity[]

  @@index([email])
  @@map("crm_customers")
}

model CrmActivity {
  id         String      @id @default(cuid())
  customerId String
  customer   CrmCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type       String      // 'note', 'order', 'status_change', 'tag_change'
  content    String
  createdBy  String?     // admin name
  createdAt  DateTime    @default(now())

  @@index([customerId])
  @@index([createdAt])
  @@map("crm_activities")
}

enum TicketStatus {
  NEW
  OPEN
  PENDING
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Ticket {
  id           String         @id @default(cuid())
  ticketNumber Int            @default(autoincrement())
  subject      String
  status       TicketStatus   @default(NEW)
  priority     TicketPriority @default(LOW)
  group        String         @default("Miscellaneous")
  contactEmail String
  contactName  String
  assignedTo       String?        // admin name or email
  firstResponseDue DateTime?
  resolutionDue    DateTime?
  firstRespondedAt DateTime?
  resolvedAt       DateTime?
  mergedIntoId     String?        // if merged, points to parent ticket
  tags             String?        // comma-separated tags
  lastViewedBy     String?        // for collision detection
  lastViewedAt     DateTime?      // for collision detection
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  messages         TicketMessage[]
  activities       TicketActivity[]

  @@index([status])
  @@index([contactEmail])
  @@index([createdAt])
  @@map("tickets")
}

model TicketMessage {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender    String   // 'customer', 'agent', or 'system'
  senderName String
  content   String
  isInternal Boolean @default(false)  // internal note, not visible to customer
  createdAt DateTime @default(now())

  @@index([ticketId])
  @@index([createdAt])
  @@map("ticket_messages")
}

model TicketActivity {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  action    String   // 'created', 'status_changed', 'priority_changed', 'assigned', 'merged', 'replied', 'note_added'
  details   String   // human-readable description
  performedBy String?
  createdAt DateTime @default(now())

  @@index([ticketId])
  @@index([createdAt])
  @@map("ticket_activities")
}

model CannedResponse {
  id        String   @id @default(cuid())
  title     String
  content   String
  folder    String   @default("General")
  tags      String?  // comma-separated tags
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([folder])
  @@map("canned_responses")
}

model CustomerPin {
  id        String   @id @default(cuid())
  email     String   @unique
  pin       String   // 6-digit PIN
  createdAt DateTime @default(now())

  @@index([email])
  @@map("customer_pins")
}

model AdminUser {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  @@map("admin_users")
}

model ErrorLog {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  level      String   @default("error")  // error | warning | info
  source     String   @default("server") // server | client | bot
  message    String
  stack      String?  @db.Text
  url        String?  // page / route where error occurred
  method     String?  // HTTP method for server errors
  statusCode Int?
  userAgent  String?
  ipAddress  String?
  userEmail  String?  // who was affected
  userType   String?  // admin | customer | guest
  context    String?  @db.Text // JSON blob of extra context
  sentryId   String?  // Sentry event ID if forwarded
  fingerprint String? // hash of message+stack to group similar errors
  resolved   Boolean  @default(false)
  resolvedAt DateTime?
  resolvedBy String?
  notes      String?  @db.Text

  @@index([createdAt])
  @@index([resolved])
  @@index([level])
  @@index([fingerprint])
  @@map("error_logs")
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NOTE: `status` is a String (not an enum) so admins can define custom status
// codes via /admin/settings/india → Status Labels. Built-in codes are:
//   UNFINISHED, PROCESSING, SUBMITTED, COMPLETED, NEEDS_CORRECTION,
//   ON_HOLD, REJECTED, REFUNDED
// Legacy codes still valid: PENDING, UNDER_REVIEW, APPROVED.

model Order {
  id           String      @id @default(cuid())
  orderNumber  Int         @default(autoincrement())
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  destination  String
  visaType     String
  totalUSD     Float
  status       String      @default("UNFINISHED")
  notes        String?
  travelers    String
  billingEmail String
  cardLast4       String?
  processingSpeed String   @default("standard")
  // Optional add-on: "Rejection Protection Plan" — a flat-fee insurance
  // line the customer can opt into either at checkout or later from
  // /status. Price lives in Setting key `pricing.addons.rejectionProtection`
  // so admins can adjust without redeploying. When true, the add-on's
  // price was folded into totalUSD at the time it was purchased.
  rejectionProtection Boolean @default(false)
  lastEditedBy    String?
  applicationId   String?
  evisaUrl         String?
  flaggedFields    String?  // JSON array of field names
  specialistNotes  String?  // Customer-visible correction notes
  botFlags         String?  // JSON array of bot processing issues that need manual attention
  // Per-document approval — null means "not yet reviewed/approved by an
  // admin". Set to NOW + admin name when the admin clicks "Approve" next to
  // the document on the order detail page. AUTO-CLEARED whenever the
  // matching URL (photoUrl / passportBioUrl in the travelers JSON) changes
  // — so any re-upload (by customer or admin) forces a fresh review. The
  // bot refuses to start while either approvedAt is null.
  photoApprovedAt     DateTime?
  photoApprovedBy     String?
  passportApprovedAt  DateTime?
  passportApprovedBy  String?
  // Free-form admin tags — JSON array of OrderTag.id values. The catalog
  // lives in the OrderTag model (admin-defined). Used for organizational
  // workflow: "Photos Edited", "VIP", "Customer Replied", etc.
  tags             String?
  refundAmount     Float?
  refundReason    String?
  refundedAt      DateTime?
  // Reminders for UNFINISHED orders
  reminderCount    Int      @default(0)
  lastReminderAt   DateTime?
  completedAt      DateTime?
  submittedAt      DateTime?
  // Archive: set when a COMPLETED order is moved to the Archive tab by the
  // daily cron (30 days after completedAt). While non-null, the detail view
  // renders a redacted card — admins click Recover to null this out.
  archivedAt       DateTime?
  // Track which emails have been sent (JSON: { "confirmation": "2026-04-18T...", "correction": "...", ... })
  emailHistory     String?   @db.Text

  @@index([status])
  @@index([createdAt])
  @@index([archivedAt])
  @@map("orders")
}

model AbandonedApplication {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  destination String?
  visaType    String?
  email       String?
  travelers   String?  // JSON string of partial traveler data
  passportData String? // JSON string of partial passport data
  lastStep    String   @default("step1") // step1, step2, step2b, step3
  ipAddress   String?
  userAgent   String?
  // Reminder tracking — daily cron sends every 2 days up to 3 times (days 2/4/6),
  // then the record is hard-deleted on day 7. Only records with a non-null email
  // are eligible for reminders.
  reminderCount  Int       @default(0)
  lastReminderAt DateTime?

  @@index([createdAt])
  @@index([email])
  @@map("abandoned_applications")
}

model CrmCustomer {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  phone     String?
  tags      String?  // comma-separated tags
  notes     String?  // internal CRM notes
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  activities CrmActivity[]

  @@index([email])
  @@map("crm_customers")
}

model CrmActivity {
  id         String      @id @default(cuid())
  customerId String
  customer   CrmCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type       String      // 'note', 'order', 'status_change', 'tag_change'
  content    String
  createdBy  String?     // admin name
  createdAt  DateTime    @default(now())

  @@index([customerId])
  @@index([createdAt])
  @@map("crm_activities")
}

enum TicketStatus {
  NEW
  OPEN
  PENDING
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Ticket {
  id           String         @id @default(cuid())
  ticketNumber Int            @default(autoincrement())
  subject      String
  status       TicketStatus   @default(NEW)
  priority     TicketPriority @default(LOW)
  group        String         @default("Miscellaneous")
  contactEmail String
  contactName  String
  assignedTo       String?        // admin name or email
  firstResponseDue DateTime?
  resolutionDue    DateTime?
  firstRespondedAt DateTime?
  resolvedAt       DateTime?
  mergedIntoId     String?        // if merged, points to parent ticket
  tags             String?        // comma-separated tags
  lastViewedBy     String?        // for collision detection
  lastViewedAt     DateTime?      // for collision detection
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  messages         TicketMessage[]
  activities       TicketActivity[]

  @@index([status])
  @@index([contactEmail])
  @@index([createdAt])
  @@map("tickets")
}

model TicketMessage {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender    String   // 'customer', 'agent', or 'system'
  senderName String
  content   String
  isInternal Boolean @default(false)  // internal note, not visible to customer
  createdAt DateTime @default(now())

  @@index([ticketId])
  @@index([createdAt])
  @@map("ticket_messages")
}

model TicketActivity {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  action    String   // 'created', 'status_changed', 'priority_changed', 'assigned', 'merged', 'replied', 'note_added'
  details   String   // human-readable description
  performedBy String?
  createdAt DateTime @default(now())

  @@index([ticketId])
  @@index([createdAt])
  @@map("ticket_activities")
}

model CannedResponse {
  id        String   @id @default(cuid())
  title     String
  content   String
  folder    String   @default("General")
  tags      String?  // comma-separated tags
  // Visibility — "shared" (any admin can see + use) or "personal" (only the
  // creator). Mirrors Freshdesk's personal/all-agents distinction; we don't
  // do per-group visibility yet.
  visibility String  @default("shared")
  // Slash-command keyword for the in-reply autocomplete. Stored without the
  // leading "/", so a user typing `/welcome` matches `shortcut: "welcome"`.
  // Optional — responses without a shortcut still work via the picker UI.
  shortcut   String?
  // Per-response usage stats — each call to /api/canned/[id]/use bumps
  // usageCount and updates lastUsedAt. Drives the "most-used" sort in the
  // ticket-reply picker so frequently-used responses surface first.
  usageCount Int      @default(0)
  lastUsedAt DateTime?
  createdBy  String?
  updatedBy  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([folder])
  @@index([visibility])
  @@index([shortcut])
  @@map("canned_responses")
}

model CustomerPin {
  id        String   @id @default(cuid())
  email     String   @unique
  pin       String   // 6-digit PIN
  createdAt DateTime @default(now())

  @@index([email])
  @@map("customer_pins")
}

// Owner-driven page customizations — Phase 2 of the site editor. Each row
// is one CSS-property override (or text/visibility override) targeting a
// specific element via a CSS selector. Owners create drafts in edit mode
// at /admin (any page); a separate Publish action flips drafts → published
// at which point all visitors see the change.
//
// pagePath = '*' means site-wide (applies on every page); otherwise the
// exact path the override applies to (e.g. '/admin/orders'). The unique
// constraint includes status so a single (path, selector, property) slot
// can have BOTH a draft and a published row simultaneously — visitors see
// published; the owner in edit mode sees their draft.
model PageCustomization {
  id         String   @id @default(cuid())
  pagePath   String                                // '*' for site-wide, else exact path
  selector   String                                // CSS selector for the target element
  property   String                                // 'color' | 'background-color' | 'font-size' | … | special: 'text' | 'hidden'
  value      String                                // the override value (CSS string or content)
  status     String   @default("draft")            // 'draft' | 'published'
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  updatedBy  String?

  @@unique([pagePath, selector, property, status])
  @@index([pagePath, status])
  @@map("page_customizations")
}

model AdminUser {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  // 'owner' has full access (employee mgmt, theme editor, future page editor).
  // 'employee' can use the admin panel but can't manage other admins or
  // customise the site. Defaults to 'employee' so accidentally-created rows
  // don't get unintended privileges; the seed/owner is set explicitly.
  role      String   @default("employee")
  createdAt DateTime @default(now())

  @@map("admin_users")
}

model Setting {
  key       String   @id                  // e.g. "pricing.visa.TOURIST_30", "email.confirmation"
  category  String                         // "pricing" | "email" | "status" | "general"
  value     String   @db.Text              // JSON blob
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@index([category])
  @@map("settings")
}

model CustomStatus {
  id          String   @id @default(cuid())
  country     String   @default("INDIA")  // which country this applies to
  code        String                       // unique per country — stored on Order.status
  label       String                       // display name
  color       String   @default("slate")   // slate | blue | green | amber | red | purple | pink | emerald
  description String?
  sortOrder   Int      @default(50)        // ordering among all statuses (lower = earlier)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String?

  @@unique([country, code])
  @@index([country])
  @@map("custom_statuses")
}

// Admin-defined tag catalog for orders. Each Order references zero or more
// tags via Order.tags (JSON array of OrderTag.id). Used for workflow
// organization: "Photos Edited", "VIP", "Customer Replied", "Pending Refund",
// etc. — admin defines whatever is useful.
model OrderTag {
  id          String   @id @default(cuid())
  name        String   @unique          // display name; admin-editable
  color       String   @default("blue") // slate | blue | green | amber | red | purple | pink | emerald
  icon        String?                    // optional emoji (e.g. "📸"), shown before the name
  description String?                    // hover hint
  sortOrder   Int      @default(50)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String?

  @@index([sortOrder])
  @@map("order_tags")
}

model CustomEmailTemplate {
  id          String   @id @default(cuid())
  country     String   @default("INDIA")  // which country this applies to
  code        String                       // unique per country — used to identify the template
  label       String                       // display name in admin panel
  description String?
  trigger     String   @default("manual") // "manual" | "on_status_UNFINISHED" | "on_status_PROCESSING" | etc.
  subject     String
  structured  String?  @db.Text            // JSON of StructuredEmail
  html        String?  @db.Text            // raw HTML override (takes precedence over structured)
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String?

  @@unique([country, code])
  @@index([country])
  @@index([trigger])
  @@map("custom_email_templates")
}

model BotRun {
  id          String          @id @default(cuid())
  orderId     String
  startedAt   DateTime        @default(now())
  finishedAt  DateTime?
  status      String          @default("running")  // running | completed | failed | cancelled
  country     String          @default("INDIA")
  errorMsg    String?         @db.Text
  entries     BotRunEntry[]

  @@index([orderId])
  @@index([startedAt])
  @@map("bot_runs")
}

model BotRunEntry {
  id            String   @id @default(cuid())
  runId         String
  run           BotRun   @relation(fields: [runId], references: [id], onDelete: Cascade)
  stepKey       String                    // e.g. "registration"
  fieldKey      String                    // e.g. "nationality"
  label         String                    // human-readable label at the time of run
  action        String                    // fill | select | click | check | upload | skip | manual
  source        String                    // admin | default | manual | skip
  value         String?  @db.Text         // the value the bot tried to use (string)
  success       Boolean  @default(true)
  errorMsg      String?  @db.Text         // if success=false, why
  selector      String?                   // the selector used
  createdAt     DateTime @default(now())

  @@index([runId])
  @@index([stepKey])
  @@map("bot_run_entries")
}

model ErrorLog {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  level      String   @default("error")  // error | warning | info
  source     String   @default("server") // server | client | bot
  message    String
  stack      String?  @db.Text
  url        String?  // page / route where error occurred
  method     String?  // HTTP method for server errors
  statusCode Int?
  userAgent  String?
  ipAddress  String?
  userEmail  String?  // who was affected
  userType   String?  // admin | customer | guest
  context    String?  @db.Text // JSON blob of extra context
  sentryId   String?  // Sentry event ID if forwarded
  fingerprint String? // hash of message+stack to group similar errors
  resolved   Boolean  @default(false)
  resolvedAt DateTime?
  resolvedBy String?
  notes      String?  @db.Text

  @@index([createdAt])
  @@index([resolved])
  @@index([level])
  @@index([fingerprint])
  @@map("error_logs")
}

# Copy this to .env and fill in your values
# Run: cp .env.example .env

# Database — matches docker-compose.yml defaults
DATABASE_URL="postgresql://expressvisa:expressvisa@localhost:5432/expressvisa"

# Next.js
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Sentry (optional — if set, errors are sent to Sentry AND our DB)
# Get your DSN from https://sentry.io → create project (Next.js) → Settings → Client Keys
# NEXT_PUBLIC_SENTRY_DSN="https://xxx@yyy.ingest.sentry.io/zzz"
# SENTRY_DSN="https://xxx@yyy.ingest.sentry.io/zzz"
# SENTRY_ORG="your-org-slug"
# SENTRY_PROJECT="visatrips"
# SENTRY_AUTH_TOKEN=""  # Needed for source map uploads in production
